{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/submit", "dest": "/api/submit.js" },
    { "src": "/api/action", "dest": "/api/action.js" },
    { "src": "/api/confirm", "dest": "/api/confirm.js" },
    { "src": "/thanks", "dest": "/thanks.html" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
